{
    "name": "@dpuse/dpuse-presenter-default",
    "version": "0.1.1019",
    "description": "A library that implements the default presenter in accordance with the Data Positioning presenter interface.",
    "license": "MIT",
    "private": false,
    "type": "module",
    "homepage": "https://www.dpuse.app",
    "repository": {
        "type": "git",
        "url": "https://github.com/dpuse/dpuse-presenter-default.git"
    },
    "bugs": {
        "url": "https://github.com/dpuse/dpuse-presenter-default/issues"
    },
    "module": "./dist/dpuse-presenter-default.es.js",
    "types": "./dist/types/src/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/dpuse-presenter-default.es.js",
            "types": "./dist/types/src/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "prettier": "@dpuse/dpuse-development/prettierrc",
    "dependencies": {
        "@datapos/datapos-tool-highcharts": "^0.0.48",
        "@datapos/datapos-tool-micromark": "^0.1.992",
        "@dpuse/dpuse-shared": "^0.3.641"
    },
    "devDependencies": {
        "@dpuse/dpuse-development": "^0.3.496",
        "@dpuse/eslint-config-dpuse": "^1.0.55",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "eslint": "^9.39.4",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-unicorn": "^63.0.0",
        "front-matter": "^4.0.2",
        "jiti": "^2.6.1",
        "license-downloader": "^1.3.3",
        "license-report": "^6.8.2",
        "license-report-check": "^1.0.0",
        "license-report-recursive": "^6.8.4",
        "npm-check-updates": "^21.0.3",
        "owasp-dependency-check": "^1.0.1",
        "prettier": "^3.8.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "sonda": "^0.11.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.9",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.4"
    },
    "scripts": {
        "audit": "op run --env-file=.env -- node -e \"import('@dpuse/dpuse-development').then(m => m.auditDependencies())\"",
        "prebuild": "tsc -p tsconfig.scripts.json && node dist-scripts/prebuild.js",
        "build": "node -e \"import('@dpuse/dpuse-development').then(m => m.buildProject())\"",
        "check": "node -e \"import('@dpuse/dpuse-development').then(m => m.checkDependencies())\"",
        "document": "op run --env-file=.env -- node -e \"import('@dpuse/dpuse-development').then(m => m.documentDependencies(['CC0-1.0','MIT']))\"",
        "format": "node -e \"import('@dpuse/dpuse-development').then(m => m.formatCode())\"",
        "lint": "node -e \"import('@dpuse/dpuse-development').then(m => m.lintCode())\"",
        "release": "op run --env-file=.env -- node -e \"import('@dpuse/dpuse-development').then(m => m.releaseProject())\"",
        "sync": "node -e \"import('@dpuse/dpuse-development').then(m => m.syncProjectWithGitHub())\"",
        "test": "node -e \"import('@dpuse/dpuse-development').then(m => m.testProject())\"",
        "update": "node -e \"import('@dpuse/dpuse-development').then(m => m.updateDPUseDependencies(['development']))\""
    }
}